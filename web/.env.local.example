# Copy this file to .env.local and fill in real values. .env.local is
# gitignored by default (see .gitignore) — never commit real secrets.

MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/uniclub

# Required by Auth.js (next-auth v5) to sign session tokens. Generate one with:
#   npx auth secret
# or: openssl rand -base64 32
AUTH_SECRET=
